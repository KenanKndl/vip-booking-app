// 1. Veritabanı Bağlantı Ayarları
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// 2. Sabit Değerler (Enums)
enum ReservationStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum GalleryCategory {
  EXTERIOR
  INTERIOR
  SPECIAL
}

enum ExtraCategory {
  GENERAL
  BABY_SEAT
}

enum TripType {
  ONE_WAY
  ROUND_TRIP
}

// 3. Sistem Ayarları (Admin Panel İçin)
model AdminSettings {
  id             String   @id @default(uuid())
  adminEmail     String   @unique
  hashedPassword String
  whatsappNumber String
  
  // Döviz Kurları
  eurToTl        Decimal  @default(35.0)
  eurToUsd       Decimal  @default(1.08)
  updatedAt      DateTime @updatedAt
}

// 4. Rotalar
model Route {
  id        String   @id @default(uuid())
  pickup    String
  dropoff   String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  prices       RoutePricing[]
  reservations Reservation[]

  @@unique([pickup, dropoff])
  @@index([isActive]) 
}

// 5. Filo ve Araçlar
model Vehicle {
  id            String   @id @default(uuid())
  name          String
  type          String
  pax           Int
  luggage       Int
  features      Json
  imageUrl      String?
  isActive      Boolean  @default(true)
  
  prices        RoutePricing[]
  reservations  Reservation[]

  @@index([isActive])
}

// 6. Fiyatlandırma 
model RoutePricing {
  id        String   @id @default(uuid())
  routeId   String
  vehicleId String
  price     Float    
  currency  String   @default("EUR") 

  route     Route    @relation(fields: [routeId], references: [id], onDelete: Cascade)
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@unique([routeId, vehicleId])
}

// 7. Ekstralar ve Donanımlar 
model Extra {
  id          String        @id @default(uuid())
  name        Json          
  price       Float         
  imageUrl    String?
  isActive    Boolean       @default(true)
  category    ExtraCategory 
  
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([isActive, category]) 
}

// 8. Rezervasyonlar
model Reservation {
  id              String   @id @default(uuid())
  pnrCode         String   @unique
  
  pickupDateTime  DateTime
  busyFrom        DateTime?
  busyTo          DateTime?
  adultCount      Int
  childCount      Int      @default(0)
  
  routeId         String
  vehicleId       String
  route           Route    @relation(fields: [routeId], references: [id])
  vehicle         Vehicle  @relation(fields: [vehicleId], references: [id])

  customerName    String
  customerPhone   String
  customerEmail   String

  tripType        TripType @default(ONE_WAY) 
  pickupAddress   String?  
  dropoffAddress  String?  

  extraNotes      String?  
  customerNote    String?  

  selectedExtras  Json?

  totalPrice      Float    
  currency        String   @default("EUR")
  status          ReservationStatus @default(PENDING)
  
  originalPrice   Float?   
  originalCurrency String? 

  // YENİ: Finansal Snapshot (O anki kurların kopyası)
  exchangeRateTry Float?
  exchangeRateUsd Float?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([pnrCode])
  @@index([status, pickupDateTime])
}

// 9. Galeri Sistemi
model GalleryImage {
  id        String          @id @default(uuid())
  url       String
  category  GalleryCategory
  createdAt DateTime        @default(now())

  @@index([category]) 
}

// 10. Gelen Mesajlar 
model ContactMessage {
  id        String   @id @default(uuid())
  fullName  String
  email     String
  phone     String
  message   String   @db.Text 
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([createdAt]) 
  @@index([isRead]) 
}