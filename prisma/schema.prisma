// 1. Veritabanı Bağlantı Ayarları
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// 2. Sabit Değerler (Enums)
enum ReservationStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum GalleryCategory {
  EXTERIOR
  INTERIOR
  SPECIAL
}

// 3. Sistem Ayarları (Admin Panel İçin)
model AdminSettings {
  id             String   @id @default(uuid())
  adminEmail     String   @unique
  hashedPassword String
  whatsappNumber String
  updatedAt      DateTime @updatedAt
}

// 4. Rotalar (Nereden -> Nereye - Frontend'deki yapıya uygun hale getirildi)
model Route {
  id        String   @id @default(uuid())
  pickup    String   // Kalkış Noktası (Örn: Antalya Havalimanı)
  dropoff   String   // Varış Noktası (Örn: Kemer)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  prices       RoutePricing[]
  reservations Reservation[]

  @@unique([pickup, dropoff]) // Aynı rotanın mükerrer eklenmesini önler
}

// 5. Filo ve Araçlar
model Vehicle {
  id            String   @id @default(uuid())
  name          String   // Örn: Maybach Royal Class VIP
  type          String   // Örn: Binek VIP
  pax           Int      // Yolcu Kapasitesi
  luggage       Int      // Bagaj Kapasitesi
  features      String[] // Örn: ["Wifi", "Tv", "Atıştırmalık"]
  imageUrl      String?
  isActive      Boolean  @default(true)
  
  prices        RoutePricing[]
  reservations  Reservation[]
}

// 6. Fiyatlandırma (Hangi Rota, Hangi Araç, Ne Kadar?)
model RoutePricing {
  id        String   @id @default(uuid())
  routeId   String
  vehicleId String
  price     Float
  currency  String   @default("₺") // Enum yerine String yapıldı (₺, $, € kabul eder)

  route     Route    @relation(fields: [routeId], references: [id], onDelete: Cascade)
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@unique([routeId, vehicleId]) // Bir rotada aynı araca sadece tek bir fiyat tanımlanabilir
}

// 7. Rezervasyonlar (Sistemin Kalbi)
model Reservation {
  id              String   @id @default(uuid())
  pnrCode         String   @unique // Örn: VIP7492
  
  // Zaman ve Yolcu Bilgileri
  pickupDateTime  DateTime
  adultCount      Int
  childCount      Int      @default(0)
  
  // Seçimler
  routeId         String
  vehicleId       String
  route           Route    @relation(fields: [routeId], references: [id])
  vehicle         Vehicle  @relation(fields: [vehicleId], references: [id])

  // Müşteri İletişim Bilgileri
  customerName    String
  customerPhone   String
  customerEmail   String

  // VIP Detayları
  flightNumber    String?  // Uçuş Numarası
  needsBabySeat   Boolean  @default(false)
  welcomeSign     String?  // İsim Tabelası
  extraNotes      String?  // Özel İstekler

  // Fiyat ve Durum Takibi
  totalPrice      Float
  currency        String   @default("₺") // Fiyatlandırma ile uyumlu olması için String yapıldı
  status          ReservationStatus @default(PENDING)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([pnrCode])
  @@index([status, pickupDateTime])
}

// 8. Galeri Sistemi
model GalleryImage {
  id        String          @id @default(uuid())
  url       String
  category  GalleryCategory
  createdAt DateTime        @default(now())
}