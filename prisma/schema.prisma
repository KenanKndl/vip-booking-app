// 1. Veritabanı Bağlantı Ayarları
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// 2. Sabit Değerler (Enums)
enum ReservationStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum GalleryCategory {
  EXTERIOR
  INTERIOR
  SPECIAL
}

// 3. Sistem Ayarları (Admin Panel İçin)
model AdminSettings {
  id             String   @id @default(uuid())
  adminEmail     String   @unique
  hashedPassword String
  whatsappNumber String
  // Yeni Döviz Kurları
  eurToTl        Decimal  @default(35.0)
  eurToUsd       Decimal  @default(1.08)
  updatedAt      DateTime @updatedAt
}

// 4. Rotalar
model Route {
  id        String   @id @default(uuid())
  pickup    String
  dropoff   String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  prices       RoutePricing[]
  reservations Reservation[]

  @@unique([pickup, dropoff])
}

// 5. Filo ve Araçlar
model Vehicle {
  id            String   @id @default(uuid())
  name          String
  type          String
  pax           Int
  luggage       Int
  features      String[]
  imageUrl      String?
  isActive      Boolean  @default(true)
  
  prices        RoutePricing[]
  reservations  Reservation[]
}

// 6. Fiyatlandırma (Her zaman EURO bazlı)
model RoutePricing {
  id        String   @id @default(uuid())
  routeId   String
  vehicleId String
  price     Float    // Bu değer artık her zaman EURO cinsindendir
  currency  String   @default("EUR") 

  route     Route    @relation(fields: [routeId], references: [id], onDelete: Cascade)
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@unique([routeId, vehicleId])
}

// 7. Rezervasyonlar
model Reservation {
  id              String   @id @default(uuid())
  pnrCode         String   @unique
  
  pickupDateTime  DateTime
  busyFrom        DateTime?
  busyTo          DateTime?
  adultCount      Int
  childCount      Int      @default(0)
  
  routeId         String
  vehicleId       String
  route           Route    @relation(fields: [routeId], references: [id])
  vehicle         Vehicle  @relation(fields: [vehicleId], references: [id])

  customerName    String
  customerPhone   String
  customerEmail   String

  flightNumber    String?
  needsBabySeat   Boolean  @default(false)
  welcomeSign     String?
  extraNotes      String?

  totalPrice      Float
  currency        String   @default("EUR")
  status          ReservationStatus @default(PENDING)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([pnrCode])
  @@index([status, pickupDateTime])
}

// 8. Galeri Sistemi
model GalleryImage {
  id        String        @id @default(uuid())
  url       String
  category  GalleryCategory
  createdAt DateTime        @default(now())
}