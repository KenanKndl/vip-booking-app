// 1. Veritabanı Bağlantı Ayarları
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// 2. Sabit Değerler (Enums)
enum ReservationStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum GalleryCategory {
  EXTERIOR
  INTERIOR
  SPECIAL
}

// YENİ: Ekstra ürünlerin kategorileri
enum ExtraCategory {
  GENERAL
  BABY_SEAT
}

// YENİ: Yolculuk Tipi (Tek Yön / Gidiş-Dönüş)
enum TripType {
  ONE_WAY
  ROUND_TRIP
}

// 3. Sistem Ayarları (Admin Panel İçin)
model AdminSettings {
  id             String   @id @default(uuid())
  adminEmail     String   @unique
  hashedPassword String
  whatsappNumber String
  
  // Döviz Kurları
  eurToTl        Decimal  @default(35.0)
  eurToUsd       Decimal  @default(1.08)
  updatedAt      DateTime @updatedAt
}

// 4. Rotalar
model Route {
  id        String   @id @default(uuid())
  pickup    String
  dropoff   String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  prices       RoutePricing[]
  reservations Reservation[]

  @@unique([pickup, dropoff])
  @@index([isActive]) // Optimizasyon: Sadece aktif rotaları çekerken hızlandırır
}

// 5. Filo ve Araçlar
model Vehicle {
  id            String   @id @default(uuid())
  name          String
  type          String
  pax           Int
  luggage       Int
  
  // GÜNCELLEME: Çoklu dil destekli JSON (Örn: [{ "id": "f1", "tr": "Wifi", "en": "Wifi" }])
  features      Json
  
  imageUrl      String?
  isActive      Boolean  @default(true)
  
  prices        RoutePricing[]
  reservations  Reservation[]

  @@index([isActive]) // Optimizasyon: Aktif araç listelemeyi hızlandırır
}

// 6. Fiyatlandırma (Her zaman EURO bazlı)
model RoutePricing {
  id        String   @id @default(uuid())
  routeId   String
  vehicleId String
  price     Float    // Bu değer artık her zaman EURO cinsindendir
  currency  String   @default("EUR") 

  route     Route    @relation(fields: [routeId], references: [id], onDelete: Cascade)
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@unique([routeId, vehicleId])
}

// YENİ 7. Ekstralar ve Donanımlar (Upselling)
model Extra {
  id          String        @id @default(uuid())
  // JSON Formatı: { "tr": "Puset", "en": "Stroller", "de": "Kinderwagen", "ru": "Коляска" }
  name        Json          
  price       Float         // Euro bazlı ekstra fiyatı
  imageUrl    String?       // Ekstra ürün görseli
  isActive    Boolean       @default(true)
  category    ExtraCategory // GENERAL veya BABY_SEAT
  
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([isActive, category]) // Optimizasyon: Müşteri ekranında kategoriye göre aktif ekstraları anında getirir
}

// 8. Rezervasyonlar
model Reservation {
  id              String   @id @default(uuid())
  pnrCode         String   @unique
  
  pickupDateTime  DateTime
  busyFrom        DateTime?
  busyTo          DateTime?
  adultCount      Int
  childCount      Int      @default(0)
  
  routeId         String
  vehicleId       String
  route           Route    @relation(fields: [routeId], references: [id])
  vehicle         Vehicle  @relation(fields: [vehicleId], references: [id])

  // İletişim Bilgileri
  customerName    String
  customerPhone   String
  customerEmail   String

  // YENİ: Arayüzden Gelen Transfer Detayları
  tripType        TripType @default(ONE_WAY) // Tek Yön / Gidiş Dönüş
  pickupAddress   String?  // Alınacak adres / hotel adı
  dropoffAddress  String?  // Bırakılacak adres / hotel adı

  // Ekstra Notlar ve Detaylar
  extraNotes      String?  // Rezervasyon notu (Uçuş numarası vb.)

  // YENİ: Seçilen Ekstraların JSON formatında tutulması
  // Format: [{ "extraId": "uuid", "quantity": 2, "priceAtThatTime": 15 }]
  selectedExtras  Json?

  // Ödeme ve Durum
  totalPrice      Float    // Araç Fiyatı + (Ekstra Fiyatları Toplamı)
  currency        String   @default("EUR")
  status          ReservationStatus @default(PENDING)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([pnrCode])
  @@index([status, pickupDateTime])
}

// 9. Galeri Sistemi
model GalleryImage {
  id        String          @id @default(uuid())
  url       String
  category  GalleryCategory
  createdAt DateTime        @default(now())

  @@index([category]) // Optimizasyon: Galeride kategoriye tıklandığında hızlı filtreleme sağlar
}